{
  "manifest_version": 3,
  "name": "Mouseless (dev)",
  "version": "0.0.8",
  "description": "Bridge between Chrome and the Mouseless desktop app. Dev build — multi-profile / multi-browser active routing.",
  "minimum_chrome_version": "120",
  "permissions": ["nativeMessaging", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Mouseless: click to ping native host"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["detector.js", "content_script.js"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true
    }
  ]
}
